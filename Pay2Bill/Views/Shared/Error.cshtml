@model HandleErrorInfo
@{
    ViewBag.Title = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm text-center mt-5">
            <div class="card-body py-5">
                <div class="icon-circle bg-danger bg-opacity-10 mx-auto mb-3" style="width:100px;height:100px;">
                    <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
                </div>
                <h2>Something went wrong</h2>
                <p class="text-muted mb-4">An unexpected error has occurred. Please try again later.</p>
                <a href="@Url.Action("Index", "Home")" class="btn btn-primary"><i class="bi bi-house-door me-1"></i>Return to Home</a>
            </div>
        </div>
    </div>
</div>
