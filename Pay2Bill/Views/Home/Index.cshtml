@model IEnumerable<Pay2Bill.Models.Bill>
@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var unpaidBills = Model.Where(b => !b.IsPaid).ToList();
}

<div class="row">
    <div class="col-12 text-center mb-4">
        <div class="hero-section py-4">
            <i class="bi bi-credit-card-2-front display-3 text-primary mb-3 d-block"></i>
            <h1 class="display-5 fw-bold">Welcome to Pay2Bill</h1>
            <p class="lead text-muted">Azure App Service Demo &mdash; Simplified Bill Payment Application</p>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Summary Cards -->
    <div class="col-md-4">
        <div class="card border-0 h-100 shadow-sm summary-card">
            <div class="card-body text-center">
                <div class="icon-circle bg-primary bg-opacity-10 mx-auto mb-3">
                    <i class="bi bi-receipt-cutoff display-5 text-primary"></i>
                </div>
                <h5 class="card-title">Total Bills</h5>
                <p class="card-text display-6 fw-bold">@Model.Count()</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 h-100 shadow-sm summary-card">
            <div class="card-body text-center">
                <div class="icon-circle bg-warning bg-opacity-10 mx-auto mb-3">
                    <i class="bi bi-clock-history display-5 text-warning"></i>
                </div>
                <h5 class="card-title">Unpaid Bills</h5>
                <p class="card-text display-6 fw-bold text-warning">@unpaidBills.Count</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 h-100 shadow-sm summary-card">
            <div class="card-body text-center">
                <div class="icon-circle bg-danger bg-opacity-10 mx-auto mb-3">
                    <i class="bi bi-currency-dollar display-5 text-danger"></i>
                </div>
                <h5 class="card-title">Amount Due</h5>
                <p class="card-text display-6 fw-bold text-danger">@unpaidBills.Sum(b => b.AmountDue).ToString("C")</p>
            </div>
        </div>
    </div>
</div>

@if (unpaidBills.Any())
{
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning bg-opacity-10 border-bottom">
                    <strong><i class="bi bi-exclamation-triangle text-warning me-2"></i>Pending Bills</strong>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Type</th>
                                <th>Account</th>
                                <th>Customer</th>
                                <th>Description</th>
                                <th>Amount Due</th>
                                <th>Due Date</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bill in unpaidBills)
                            {
                                <tr class="@(bill.DueDate < DateTime.Today ? "table-danger" : "")">
                                    <td>
                                        <span class="badge @(bill.Type == Pay2Bill.Models.BillType.Internet ? "bg-info" : "bg-secondary")">
                                            <i class="bi bi-@bill.TypeIcon me-1"></i>@bill.TypeDisplayName
                                        </span>
                                    </td>
                                    <td><code>@bill.AccountNumber</code></td>
                                    <td>@bill.CustomerName</td>
                                    <td>@bill.Description</td>
                                    <td class="fw-bold">@bill.AmountDue.ToString("C")</td>
                                    <td class="@(bill.DueDate < DateTime.Today ? "text-danger fw-bold" : "")">
                                        @bill.DueDate.ToString("MMM dd, yyyy")
                                        @if (bill.DueDate < DateTime.Today)
                                        {
                                            <span class="badge bg-danger ms-1"><i class="bi bi-exclamation-circle me-1"></i>Overdue</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Pay", "Bill", new { id = bill.Id })"
                                           class="btn btn-sm btn-primary"><i class="bi bi-credit-card me-1"></i>Pay Now</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-success text-center mt-3 border-0 shadow-sm">
        <i class="bi bi-check-circle display-6 d-block mb-2"></i>
        <h4>All bills are paid!</h4>
        <p class="mb-0">You have no outstanding bills at this time.</p>
    </div>
}

<div class="row mt-5">
    <div class="col-12">
        <div class="card border-0 bg-light shadow-sm">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-diagram-3 me-2 text-primary"></i>Architecture Note</h5>
                <p class="card-text text-muted small">
                    This is a demo application running on <strong>Azure App Service</strong> using
                    <strong>.NET Framework 4.8</strong>. It demonstrates health checks at
                    <a href="/health/ui">/health</a>,
                    Application Insights telemetry, and mock dependency validation.
                    See the <a href="https://github.com/dvazqueb11/demo-pay2bill-app" target="_blank">README</a> for architecture details.
                </p>
            </div>
        </div>
    </div>
</div>
