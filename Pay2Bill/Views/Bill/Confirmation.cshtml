@{
    ViewBag.Title = "Payment Confirmed";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var bill = ViewBag.Bill as Pay2Bill.Models.Bill;
    var transactionId = ViewBag.TransactionId as string;
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-0 shadow text-center">
            <div class="card-body py-5">
                <div class="icon-circle bg-success bg-opacity-10 mx-auto mb-3" style="width:100px;height:100px;">
                    <i class="bi bi-check-circle display-1 text-success"></i>
                </div>
                <h2 class="card-title text-success">Payment Confirmed!</h2>
                <p class="card-text lead text-muted">Your payment has been processed successfully.</p>

                @if (!string.IsNullOrEmpty(transactionId))
                {
                    <div class="bg-light rounded p-3 my-4 text-start">
                        <div class="row g-2">
                            <div class="col-5 fw-bold text-muted"><i class="bi bi-hash me-1"></i>Transaction ID:</div>
                            <div class="col-7"><code>@transactionId</code></div>

                            @if (bill != null)
                            {
                                <div class="col-5 fw-bold text-muted"><i class="bi bi-person me-1"></i>Account:</div>
                                <div class="col-7"><code>@bill.AccountNumber</code></div>

                                <div class="col-5 fw-bold text-muted"><i class="bi bi-@bill.TypeIcon me-1"></i>Service:</div>
                                <div class="col-7">@bill.Description</div>

                                <div class="col-5 fw-bold text-muted"><i class="bi bi-currency-dollar me-1"></i>Amount Paid:</div>
                                <div class="col-7 fw-bold text-success">@bill.AmountDue.ToString("C")</div>
                            }

                            <div class="col-5 fw-bold text-muted"><i class="bi bi-calendar-check me-1"></i>Date:</div>
                            <div class="col-7">@DateTime.UtcNow.ToString("MMM dd, yyyy HH:mm") UTC</div>
                        </div>
                    </div>
                }

                <div class="d-flex gap-2 justify-content-center">
                    <a href="@Url.Action("Index", "Bill")" class="btn btn-primary"><i class="bi bi-receipt me-2"></i>Pay Another Bill</a>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary"><i class="bi bi-house-door me-1"></i>Return Home</a>
                </div>
            </div>
        </div>
    </div>
</div>
