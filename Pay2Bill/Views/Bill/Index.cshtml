@model IEnumerable<Pay2Bill.Models.Bill>
@{
    ViewBag.Title = "Pay Bills";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var unpaid = Model.Where(b => !b.IsPaid).ToList();
    var paid = Model.Where(b => b.IsPaid).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📋 Bills</h2>
</div>

@if (!unpaid.Any())
{
    <div class="alert alert-success">
        <strong>✅ All bills are paid!</strong> No outstanding balance.
    </div>
}
else
{
    <h5 class="text-warning">⏰ Unpaid Bills</h5>
    <div class="row g-3 mb-4">
        @foreach (var bill in unpaid)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm h-100 @(bill.DueDate < DateTime.Today ? "border-danger" : "")">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span class="badge @(bill.Type == Pay2Bill.Models.BillType.Internet ? "bg-info" : "bg-secondary") fs-6">
                            @bill.TypeDisplayName
                        </span>
                        @if (bill.DueDate < DateTime.Today)
                        {
                            <span class="badge bg-danger">Overdue</span>
                        }
                        else if ((bill.DueDate - DateTime.Today).TotalDays <= 3)
                        {
                            <span class="badge bg-warning text-dark">Due Soon</span>
                        }
                    </div>
                    <div class="card-body">
                        <h6 class="card-title">@bill.CustomerName</h6>
                        <p class="card-text text-muted small">@bill.Description</p>
                        <p class="mb-1"><strong>Account:</strong> <code>@bill.AccountNumber</code></p>
                        <p class="mb-1"><strong>Due:</strong> @bill.DueDate.ToString("MMM dd, yyyy")</p>
                        <p class="display-6 fw-bold text-danger mt-2">@bill.AmountDue.ToString("C")</p>
                    </div>
                    <div class="card-footer">
                        <a href="@Url.Action("Pay", "Bill", new { id = bill.Id })"
                           class="btn btn-primary w-100">Pay Now</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (paid.Any())
{
    <h5 class="text-success mt-4">✅ Paid Bills</h5>
    <div class="table-responsive">
        <table class="table table-sm table-hover">
            <thead class="table-light">
                <tr>
                    <th>Type</th>
                    <th>Account</th>
                    <th>Customer</th>
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var bill in paid)
                {
                    <tr class="text-muted">
                        <td>
                            <span class="badge @(bill.Type == Pay2Bill.Models.BillType.Internet ? "bg-info" : "bg-secondary")">
                                @bill.TypeDisplayName
                            </span>
                        </td>
                        <td><code>@bill.AccountNumber</code></td>
                        <td>@bill.CustomerName</td>
                        <td>@bill.Description</td>
                        <td>@bill.AmountDue.ToString("C")</td>
                        <td><span class="badge bg-success">Paid</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
